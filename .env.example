# Ocean.io — https://app.ocean.io/docs/searchCompaniesV3
OCEAN_API_TOKEN=

# Prospeo — https://prospeo.io/api-docs/search-person
PROSPEO_API_KEY=

# Eazyreach — https://docs.eazyreach.app/api-keys
EAZYREACH_API_KEY=
EAZYREACH_BASE_URL=https://api.eazyreach.app
EAZYREACH_ENRICH_PATH=/api/v1/enrich/linkedin
EAZYREACH_AUTH_HEADER=Authorization
EAZYREACH_AUTH_PREFIX=Bearer

# Email resolution: auto | prospeo | eazyreach
EMAIL_PROVIDER=auto

# Brevo — https://developers.brevo.com/reference/send-transac-email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=you@yourdomain.com
BREVO_SENDER_NAME=Your Name

# Pipeline limits
MAX_COMPANIES=25
MAX_CONTACTS_PER_COMPANY=2
OCEAN_PAGE_SIZE=50
HTTP_TIMEOUT_SECONDS=60
MAX_RETRIES=3
RETRY_BACKOFF_MS=500
